{
  "$schema": "https://opencode.ai/config.json",
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000,
    "tail_turns": 2
  },
  "provider": {
    "opencode-go": {
      "id": "opencode-go",
      "models": {
        "deepseek-v4-pro": {
          "limit": { "context": 64000, "output": 16384 }
        },
        "deepseek-v4-flash": {
          "limit": { "context": 64000, "output": 16384 }
        }
      }
    }
  }
}
