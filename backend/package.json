{
  "name": "modular-monolith-backend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/core/server.js",
    "start": "node src/core/server.js",
    "lint:boundaries": "node scripts/check-module-boundaries.mjs",
    "lint:layers": "node scripts/check-module-layers.mjs",
    "lint:api-docs": "node ../scripts/check-api-docs.mjs",
    "lint:architecture": "npm run lint:boundaries && npm run lint:layers && npm run lint:api-docs && npm run test:contracts",
    "test": "node --test && npm run test:contracts && node --test scripts/boundary-lint.test.mjs",
    "condense-models": "node ../scripts/condense-models.mjs",
    "condense-prompts": "node ../scripts/condense-prompts.mjs",
    "condense-file-structure": "node ../scripts/condense-file-structure.mjs",
    "test:contracts": "node --test src/**/*.contract.mjs",
    "test:hades-memory-isolation": "node --test src/modules/hades/tests/unit/hades.memory-isolation.tdd.test.js",
    "test:hades-workflow-orchestrator": "node --test src/modules/hades/tests/unit/hades.workflow-orchestrator.tdd.test.js",
    "test:hades-workflow-build-phases": "node --test src/modules/hades/tests/unit/hades.workflow-build-phases.tdd.test.js",
    "test:hades-workflow-durable-run-state": "node --test src/modules/hades/tests/unit/hades.workflow-durable-run-state.tdd.test.js",
    "test:hades-extension-install": "node --test src/modules/hades/tests/unit/hades.extension-install.tdd.test.js",
    "test:hades-extension-auth": "node --test src/modules/hades/tests/unit/hades.extension-auth.tdd.test.js",
    "test:hades-media-verification": "node --test src/modules/hades/tests/unit/mediaUrlVerifier.tdd.test.js src/modules/hades/tests/unit/discordGifMediaVerification.tdd.test.js src/modules/hades/tests/unit/giphyProvider.test.js",
    "test:hades-instagram-social": "node --test src/modules/hades/tests/unit/instagramSocialRoutes.tdd.test.js",
    "test:hades-inline-gif-media": "node --test src/modules/hades/tests/unit/hermes.service.test.js",
    "test:hades-autonomous-hermes-runtime": "node --test src/modules/hades/tests/unit/hades.autonomous-hermes-runtime.tdd.test.js src/modules/hades/tests/unit/hades.autonomous-hermes-persistence.tdd.test.js src/modules/hades/tests/unit/hades.autonomous-hermes-bridge-gaps.tdd.test.js",
    "test:evals": "node ../scripts/run-module-evals.mjs"
  },
  "dependencies": {
    "@napi-rs/canvas": "0.1.100",
    "@neondatabase/serverless": "^1.1.0",
    "@supabase/supabase-js": "^2.108.1",
    "archiver": "^7.0.1",
    "better-sqlite3": "^11.10.0",
    "bullmq": "^5.77.6",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "ioredis": "^5.11.0",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "5.4.296",
    "word-extractor": "^1.0.4"
  }
}
