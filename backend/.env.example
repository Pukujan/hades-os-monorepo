# Backend — copy to backend/.env

PORT=3001
NODE_ENV=development

# Hades MVP backend
HADES_USER_ID=local-user
HERMES_MODE=openrouter_with_fallback
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Hermes sync source of truth
# `npm run hermes:sync-config` reads this same backend file and generates ~/.hermes/config.yaml.
# Add Hermes overrides here when you want the backend app and Hermes CLI to stay aligned.
HERMES_PROVIDER=openrouter
HERMES_MODEL=deepseek/deepseek-v4-flash
HERMES_BASE_URL=https://openrouter.ai/api/v1
HERMES_CONTEXT_LENGTH=30720

OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=Hades OS
CORS_ORIGIN=http://localhost:5173

# Optional local artifact overrides
# ARTIFACT_ROOT=
# FILE_EXCHANGE_ROOT=
# EVAL_BUNDLE_ROOT_DIR=
# CASE_EXPORT_ROOT_DIR=

# Model condenser
MODEL_CONDENSER_OUTPUT_DIR=
MODEL_CONDENSER_OUTPUT_FILE=consolidated-models.json

# Document persistence template
# DATABASE_URL=postgresql://USER:PASS@host/db?sslmode=require
# QUEUE_DISABLED=true

# Async jobs template
# REDIS_URL=redis://127.0.0.1:6379
# QUEUE_DISABLED=true
