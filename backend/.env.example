# Backend — copy to backend/.env

PORT=3001
NODE_ENV=development

# === Hermes Runtime (required in production, mandatory by default) ===
# HERMES_REQUIRED=true by default; set to "false" to start without Hermes.
HERMES_REQUIRED=true
# Set HERMES_BIN_PATH to a custom Hermes binary location.
# If unset, the system PATH is searched.
HERMES_BIN_PATH=
# Set HERMES_HOME to a writable directory for Hermes state
# (defaults to /tmp/hades-hermes in production).
HERMES_HOME=

# === Supabase (required for persistence) ===
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# === OpenRouter (Hermes provider config) ===
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=Hades OS

# === Encryption key (for AES-256-GCM token encryption) ===
# Generate with: openssl enc -aes-256-gcm -k "" -P | grep -o 'key=[A-F0-9]*' | cut -d= -f2
# Or: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# === Optional integrations ===
GIPHY_API_KEY=
TELEGRAM_BOT_TOKEN=

# === CORS ===
CORS_ORIGIN=http://localhost:5173

# === Optional local artifact overrides ===
# ARTIFACT_ROOT=
# FILE_EXCHANGE_ROOT=
# EVAL_BUNDLE_ROOT_DIR=
# CASE_EXPORT_ROOT_DIR=

# === Model condenser ===
MODEL_CONDENSER_OUTPUT_DIR=
MODEL_CONDENSER_OUTPUT_FILE=consolidated-models.json

# === Document persistence template ===
# DATABASE_URL=postgresql://USER:PASS@host/db?sslmode=require
# QUEUE_DISABLED=true

# === Async jobs template ===
# REDIS_URL=redis://127.0.0.1:6379
# QUEUE_DISABLED=true
