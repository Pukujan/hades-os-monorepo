# Backend — copy to backend/.env

PORT=3001
NODE_ENV=development

# Hades MVP backend
HADES_USER_ID=local-user
HERMES_MODE=private_ai_with_fallback
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
PRIVATE_AI_BASE_URL=
PRIVATE_AI_API_KEY=
CORS_ORIGIN=http://localhost:5173

# Optional local artifact overrides
# ARTIFACT_ROOT=
# FILE_EXCHANGE_ROOT=
# EVAL_BUNDLE_ROOT_DIR=
# CASE_EXPORT_ROOT_DIR=

# Model condenser
MODEL_CONDENSER_OUTPUT_DIR=
MODEL_CONDENSER_OUTPUT_FILE=consolidated-models.json

# Document persistence template
# DATABASE_URL=postgresql://USER:PASS@host/db?sslmode=require
# QUEUE_DISABLED=true

# Async jobs template
# REDIS_URL=redis://127.0.0.1:6379
# QUEUE_DISABLED=true
