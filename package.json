{
  "name": "modular-monolith-starter",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "sync:cli-template": "node scripts/sync-cli-template.mjs",
    "export:architecture-starter": "node scripts/export-architecture-starter.mjs",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "lint:boundaries": "npm --prefix backend run lint:boundaries",
    "lint:layers": "npm --prefix backend run lint:layers",
    "lint:api-docs": "node scripts/check-api-docs.mjs",
    "lint:contracts": "node scripts/lint-contracts.mjs",
    "lint:repo-artifacts": "node scripts/lint-repo-artifacts.mjs",
    "lint:deploy": "node scripts/lint-deploy.mjs",
    "lint:architecture": "npm --prefix backend run lint:architecture",
    "test": "npm --prefix backend test && npm --prefix frontend test",
    "test:deploy": "node --test scripts/lint-deploy.test.mjs",
    "smoke:hades": "node scripts/smoke-hades-runtime.mjs",
    "smoke:hermes-context": "node scripts/smoke-hermes-context-limit.mjs",
    "smoke:hermes-chat": "node scripts/smoke-hermes-chat.mjs",
    "smoke:hermes-runtime": "node scripts/smoke-hermes-runtime.mjs",
    "hermes:sync-config": "node scripts/hermes-config-sync.mjs",
    "test:hermes-context": "node --test scripts/smoke-hermes-context-limit.test.mjs",
    "test:hermes-config": "node --test scripts/hermes-config-sync.test.mjs",
    "test:hermes-chat": "node --test scripts/smoke-hermes-chat.test.mjs",
    "test:hermes-runtime": "node --test scripts/smoke-hermes-runtime.test.mjs backend/src/modules/hades/tests/unit/hermesRuntime.service.test.js",
    "test:hades-discord-gif-contract": "node --test backend/src/modules/hades/tests/contracts/hades.discord-gif.contract.mjs",
    "test:hades-minion-assignment-runtime-contract": "node --test backend/src/modules/hades/tests/contracts/hades.minion-assignment-runtime.contract.mjs",
    "test:hades-runtime-contracts": "npm run test:hades-discord-gif-contract && npm run test:hades-minion-assignment-runtime-contract",
    "test:auth-discord-connection-contract": "node --test backend/src/modules/auth/tests/unit/auth.discord.connection.contract.test.js",
    "test:hades-discord-bot-runtime-contract": "node --test backend/src/modules/hades/tests/contracts/hades.discord-bot-runtime.contract.mjs",
    "test:discord-login-bot-contracts": "npm run test:auth-discord-connection-contract && npm run test:hades-discord-bot-runtime-contract",
    "test:evals": "npm --prefix backend run test:evals",
    "test:ci": "npm run lint:contracts && npm run lint:repo-artifacts && npm run lint:deploy && npm run lint:architecture && npm test && npm run test:deploy && npm run test:evals",
    "new:module": "node scripts/new-module.mjs",
    "condense-prompts": "node scripts/condense-prompts.mjs",
    "condense-file-structure": "node scripts/condense-file-structure.mjs",
    "condense-contracts": "node scripts/condense-contracts.mjs",
    "condense:all": "node scripts/condense-all.mjs",
    "plan:finalize": "node scripts/plan-finalize.mjs",
    "plan:gate": "node scripts/plan-gate.mjs",
    "dev-log:pre-push": "node scripts/write-pre-push-dev-log.mjs",
    "dev-log:verify": "node scripts/verify-dev-log.mjs",
    "dev-log:sync-head": "node scripts/sync-dev-log-head.mjs",
    "dev-log:install-hook": "node scripts/install-dev-log-hook.mjs",
    "import:file-exchange": "node scripts/import-to-file-exchange.mjs"
  }
}
